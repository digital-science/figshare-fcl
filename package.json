{
  "name": "@digital-science/figshare-fcl-documentation",
  "description": "Figshare components library (FCL) for research repositories",
  "engines": {
    "node": ">=22.0.0"
  },
  "version": "1.6.8",
  "main": "index.js",
  "private": true,
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css",
    "lint:css": "stylelint '**/*.css'",
    "lint:js": "eslint ./ --ext=js,jsx",
    "lint:staged": "lint-staged",
    "test": "jest",
    "test:generateJSON": "jest --json --outputFile=.jest-results.json || true",
    "storybook": "NODE_ENV=development storybook dev -p 9001",
    "storybook:build": "NODE_ENV=production storybook build -o build"
  },
  "pre-commit": {
    "run": [
      "lint:staged"
    ]
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint"
    ],
    "*.css": [
      "stylelint"
    ]
  },
  "overrides": {
    "form-data": "4.0.6",
    "immutable": "3.8.3",
    "node-fetch": "2.6.7",
    "handlebars": "4.7.9",
    "tar": "7.5.16",
    "minimatch": "3.1.3",
    "braces": "3.0.3",
    "draft-js": {
      "immutable": "3.8.3",
      "node-fetch": "2.6.7"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digital-science/figshare-fcl.git"
  },
  "keywords": [
    "figshare",
    "frontend",
    "fcl",
    "core",
    "commons"
  ],
  "author": "Digital Science",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/digital-science/figshare-fcl/issues"
  },
  "homepage": "https://github.com/digital-science/figshare-fcl#readme",
  "devDependencies": {
    "@babel/core": "7.29.6",
    "@babel/eslint-parser": "7.16.5",
    "@babel/eslint-plugin": "7.16.5",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "7.18.6",
    "@storybook/addon-docs": "8.6.14",
    "@storybook/react-webpack5": "8.6.14",
    "babel-jest": "29.7.0",
    "babel-loader": "9.2.1",
    "immutable": "3.8.3",
    "storybook": "8.6.14",
    "babel-plugin-transform-react-remove-prop-types": "0.4.24",
    "copy-webpack-plugin": "12.0.2",
    "css-loader": "6.8.1",
    "cssnano": "5.1.15",
    "enzyme": "3.11.0",
    "enzyme-to-json": "3.6.2",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "15.2.0",
    "moment": "2.29.4",
    "pixrem": "5.0.0",
    "pleeease-filters": "4.0.0",
    "postcss": "8.5.10",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-import": "16.0.0",
    "postcss-loader": "8.1.1",
    "postcss-preset-env": "10.0.0",
    "pre-commit": "1.2.2",
    "prop-types": "15.8.1",
    "react": "^17.0.0",
    "react-dom": "^17.0.0",
    "style-loader": "3.3.3",
    "webpack": "5.104.1"
  },
  "dependencies": {
    "@digital-science/figshare-fcl": "file:./packages/ui",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.8.0",
    "core-js": "3.26.1",
    "regenerator-runtime": "0.13.11"
  }
}
