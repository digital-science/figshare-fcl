{
  "name": "@digital-science/figshare-fcl-documentation",
  "description": "Figshare components library (FCL) for research repositories",
  "engines": {
    "node": ">=22.0.0"
  },
  "version": "1.6.8",
  "main": "index.js",
  "private": true,
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css",
    "lint:css": "stylelint '**/*.css'",
    "lint:js": "eslint ./ --ext=js,jsx",
    "lint:staged": "lint-staged",
    "test": "jest",
    "test:generateJSON": "jest --json --outputFile=.jest-results.json || true",
    "storybook": "NODE_ENV=development storybook dev -p 9001",
    "storybook:build": "NODE_ENV=production storybook build -o build",
    "generate-story": "node scripts/generate-story.js"
  },
  "pre-commit": {
    "run": [
      "lint:staged"
    ]
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint"
    ],
    "*.css": [
      "stylelint"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digital-science/figshare-fcl.git"
  },
  "keywords": [
    "figshare",
    "frontend",
    "fcl",
    "core",
    "commons"
  ],
  "author": "Digital Science",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/digital-science/figshare-fcl/issues"
  },
  "homepage": "https://github.com/digital-science/figshare-fcl#readme",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/eslint-parser": "^7.24.0",
    "@babel/eslint-plugin": "^7.24.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@storybook/addon-a11y": "^7.6.24",
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-interactions": "^7.6.0",
    "@storybook/blocks": "^7.6.0",
    "@storybook/components": "^7.6.0",
    "@storybook/manager-api": "^7.6.0",
    "@storybook/react-webpack5": "^7.6.0",
    "@storybook/test": "^7.6.0",
    "@storybook/theming": "^7.6.0",
    "babel-jest": "28.1.3",
    "babel-loader": "8.2.5",
    "babel-plugin-transform-react-remove-prop-types": "0.4.24",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "6.8.1",
    "cssnano": "5.1.15",
    "enzyme": "3.11.0",
    "enzyme-to-json": "3.6.2",
    "eslint": "7.32.0",
    "eslint-plugin-css-modules": "2.11.0",
    "eslint-plugin-import": "2.25.2",
    "eslint-plugin-jest": "26.0.0",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-react": "7.28.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "28.1.3",
    "jest-environment-jsdom": "^28.1.3",
    "lint-staged": "12.5.0",
    "moment": "2.29.4",
    "pixrem": "5.0.0",
    "pleeease-filters": "4.0.0",
    "postcss": "8.4.31",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-import": "14.1.0",
    "postcss-loader": "7.3.3",
    "postcss-preset-env": "7.7.2",
    "pre-commit": "1.2.2",
    "prop-types": "15.8.1",
    "react": "^17.0.0",
    "react-dom": "^17.0.0",
    "storybook": "^7.6.0",
    "storybook-addon-designs": "6.3.1",
    "style-loader": "3.3.3",
    "stylelint": "14.3.0",
    "stylelint-config-css-modules": "2.3.0",
    "stylelint-config-standard": "24.0.0",
    "stylelint-order": "5.0.0",
    "webpack": "5.89.0"
  },
  "dependencies": {
    "@digital-science/figshare-fcl": "file:./packages/ui",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.8.0",
    "core-js": "3.26.1",
    "regenerator-runtime": "0.13.11"
  }
}
